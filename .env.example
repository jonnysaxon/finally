# Required: OpenRouter API key for LLM chat functionality
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: Massive (Polygon.io) API key for real market data
# If not set, the built-in market simulator is used (recommended for most users)
MASSIVE_API_KEY=

# Optional: poll interval in seconds for the Massive source (default 15 for the
# free tier). Paid tiers can poll faster (2-15s).
MASSIVE_POLL_SECONDS=15

# Optional: Set to "true" for deterministic mock LLM responses (testing)
LLM_MOCK=false

# Optional: LLM model used for chat (defaults to the value below if unset)
LLM_MODEL=openrouter/openai/gpt-oss-120b
